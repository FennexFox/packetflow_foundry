{
  "include": [
    "builders",
    "core",
    ".agents"
  ],
  "exclude": [
    "**/__pycache__",
    ".pytest_cache"
  ],
  "executionEnvironments": [
    {
      "root": "builders/consumer-bootstrap/scripts"
    },
    {
      "root": "builders/consumer-bootstrap/tests",
      "extraPaths": [
        "builders/consumer-bootstrap/scripts",
        ".agents/skills/reword-recent-commits/scripts",
        ".agents/skills/git-split-and-commit/scripts"
      ]
    },
    {
      "root": "builders/packet-workflow/scripts"
    },
    {
      "root": "builders/packet-workflow/tests",
      "extraPaths": [
        "builders/packet-workflow/scripts"
      ]
    },
    {
      "root": ".agents/skills/gh-address-review-threads/scripts"
    },
    {
      "root": ".agents/skills/gh-address-review-threads/tests",
      "extraPaths": [
        ".agents/skills/gh-address-review-threads/scripts"
      ]
    },
    {
      "root": ".agents/skills/gh-fix-pr-writeup/scripts"
    },
    {
      "root": ".agents/skills/gh-fix-pr-writeup/tests",
      "extraPaths": [
        ".agents/skills/gh-fix-pr-writeup/scripts"
      ]
    },
    {
      "root": ".agents/skills/git-split-and-commit/scripts"
    },
    {
      "root": ".agents/skills/git-split-and-commit/tests",
      "extraPaths": [
        ".agents/skills/git-split-and-commit/scripts"
      ]
    },
    {
      "root": ".agents/skills/reword-recent-commits/scripts"
    },
    {
      "root": ".agents/skills/reword-recent-commits/tests",
      "extraPaths": [
        ".agents/skills/reword-recent-commits/scripts"
      ]
    }
  ]
}
