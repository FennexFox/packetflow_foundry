def dump_json_bytes(payload: dict) -> int:
    return len(json.dumps(payload, indent=2, sort_keys=True).encode("utf-8")) + 1


def estimate_tokens(byte_count: int) -> int:
    return max(1, (byte_count + 3) // 4)


def packet_metrics_payload(context: dict, lint: dict, packet_payloads: dict[str, dict]) -> dict:
    packet_sizes = {name: dump_json_bytes(payload) for name, payload in packet_payloads.items()}
    ordered_sizes = sorted(packet_sizes.values(), reverse=True)
    local_only_packets = {"orchestrator.json"}
    if SPEC_METADATA.get("shared_local_packet"):
        local_only_packets.add(SPEC_METADATA["shared_local_packet"])
    worker_facing_bytes = sum(
        size for name, size in packet_sizes.items() if name not in local_only_packets
    )
    local_only_bytes = dump_json_bytes(context)
    if lint:
        local_only_bytes += dump_json_bytes(lint)
    local_only_tokens = estimate_tokens(local_only_bytes)
    packet_tokens = estimate_tokens(worker_facing_bytes)
    return {
        "packet_count": len(packet_sizes),
        "packet_size_bytes": sum(packet_sizes.values()),
        "packet_size_breakdown": packet_sizes,
        "largest_packet_bytes": ordered_sizes[0] if ordered_sizes else 0,
        "largest_two_packets_bytes": sum(ordered_sizes[:2]),
        "local_only_tokens": local_only_tokens,
        "packet_tokens": packet_tokens,
        "savings_tokens": max(0, local_only_tokens - packet_tokens),
    }


def main() -> int:
    args = parse_args()
    context = load_json(Path(args.context).resolve())
__LINT_LOAD_BLOCK__
    output_dir = Path(args.output_dir).resolve()
    output_dir.mkdir(parents=True, exist_ok=True)

    ordered_packets = packet_order()
    review_mode_baseline = compute_baseline_review_mode(context)
    review_mode, override, review_mode_adjustments = apply_override_adjustment(
        review_mode_baseline,
        context,
        lint,
    )

    def build_runtime_packets(final_review_mode: str) -> tuple[dict[str, dict], list[dict], dict]:
        concrete_workers = recommended_workers(final_review_mode, review_mode_adjustments)
        qa_workers = post_draft_qa_workers(concrete_workers, final_review_mode)
        spawn_plan = common.build_spawn_plan(
            review_mode=final_review_mode,
            required_workers=concrete_workers,
            post_draft_qa_workers=qa_workers,
            common_path_sufficient=True,
        )
        packet_payloads: dict[str, dict] = {
            "orchestrator.json": orchestrator_payload(
                context,
                final_review_mode,
                review_mode_baseline,
                review_mode_adjustments,
                override,
                ordered_packets,
                spawn_plan,
            ),
            "global_packet.json": global_packet_payload(context),
        }
        packet_payloads["orchestrator.json"]["orchestrator_fingerprint"] = (
            common.orchestrator_fingerprint(packet_payloads["orchestrator.json"])
        )
        if SPEC_METADATA.get("shared_local_packet"):
            packet_payloads[SPEC_METADATA["shared_local_packet"]] = synthesis_packet_payload(
                context,
                final_review_mode,
            )

        for packet_name in PACKET_NAMES:
            packet_payloads[f"{packet_name}.json"] = __FOCUSED_PACKET_TEMPLATE__

        if USES_BATCH_PACKETS:
            packet_payloads["batch-packet-01.json"] = {
                "packet_id": "batch-packet-01",
                "packet_kind": "batch",
                "packet_targets": PACKET_NAMES,
                "context_id": context.get("context_id"),
                "todo": "Group related singleton packets here when the workflow benefits from clustering.",
            }
        return packet_payloads, concrete_workers, spawn_plan

    packet_payloads, concrete_workers, spawn_plan = build_runtime_packets(review_mode)
    provisional_packet_metrics = packet_metrics_payload(context, lint, packet_payloads)
    review_mode, review_mode_adjustments = maybe_apply_delegation_savings_floor(
        review_mode,
        provisional_packet_metrics,
        review_mode_adjustments,
    )
    if review_mode != packet_payloads["orchestrator.json"]["review_mode"]:
        packet_payloads, concrete_workers, spawn_plan = build_runtime_packets(review_mode)

    for file_name, payload in packet_payloads.items():
        write_json(output_dir / file_name, payload)

    packet_metrics = packet_metrics_payload(context, lint, packet_payloads)
    packet_sizing = common.normalize_packet_sizing(packet_metrics)
    efficiency = common.build_efficiency_payload(
        packet_metrics,
        planned_workers=common.default_planned_workers_from_spawn_plan(spawn_plan),
    )

    if SPEC_METADATA["orchestrator_profile"] == "packet-heavy-orchestrator":
        write_json(output_dir / "packet_sizing.json", packet_sizing)

    result = {
        "skill_name": SPEC_METADATA["skill_name"],
        "workflow_family": SPEC_METADATA["workflow_family"],
        "orchestrator_profile": SPEC_METADATA["orchestrator_profile"],
        "repo_profile_name": context.get("repo_profile_name"),
        "repo_profile_path": context.get("repo_profile_path"),
        "repo_profile_summary": context.get("repo_profile_summary"),
        "review_mode": review_mode,
        "review_mode_baseline": review_mode_baseline,
        "review_mode_adjustments": review_mode_adjustments,
        "spawn_plan_preview": spawn_plan,
        "packet_files": ordered_packets,
        "packet_sizing": packet_sizing,
        "efficiency": efficiency,
    }
    if SPEC_METADATA.get("shared_local_packet"):
        result["shared_local_packet"] = SPEC_METADATA["shared_local_packet"]
        result["common_path_contract"] = SPEC_METADATA["common_path_contract"]

    if args.result_output:
        write_json(Path(args.result_output).resolve(), result)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
