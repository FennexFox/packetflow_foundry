#!/usr/bin/env python3
"""Build focused packets for __SKILL_NAME__ from collected context."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path


def resolve_builder_scripts_dir() -> Path:
    script_path = Path(__file__).resolve()
    searched: list[Path] = []
    seen: set[Path] = set()
    search_bases = [*script_path.parents, Path.cwd().resolve()]
    for base in search_bases:
        for candidate in (
            base / "builders" / "packet-workflow" / "retained-skills" / "scripts",
            base
            / ".codex"
            / "vendor"
            / "packetflow_foundry"
            / "builders"
            / "packet-workflow"
            / "retained-skills"
            / "scripts",
        ):
            resolved = candidate.resolve()
            if resolved in seen:
                continue
            seen.add(resolved)
            searched.append(resolved)
            if resolved.is_dir():
                return resolved
    search_list = ", ".join(path.as_posix() for path in searched)
    raise SystemExit(
        "[ERROR] Missing packet-workflow builder scripts. "
        f"Searched: {search_list}"
    )


BUILDER_SCRIPTS_DIR = resolve_builder_scripts_dir()
while str(BUILDER_SCRIPTS_DIR) in sys.path:
    sys.path.remove(str(BUILDER_SCRIPTS_DIR))
sys.path.insert(0, str(BUILDER_SCRIPTS_DIR))

import evaluation_log_common as common  # noqa: E402


SPEC_METADATA = __SPEC_METADATA_JSON__
PACKET_NAMES = __TASK_PACKET_NAMES_JSON__
USES_BATCH_PACKETS = __USES_BATCH_PACKETS__
REVIEW_MODE_OVERRIDES = __REVIEW_MODE_OVERRIDES_JSON__
WORKER_INSTRUCTION_MAP = __WORKER_INSTRUCTION_MAP_JSON__
DELEGATION_SAVINGS_FLOOR = 250


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--context", required=True, help="Collected context JSON.")
__LINT_ARG_BLOCK__
    parser.add_argument("--output-dir", required=True, help="Packet output directory.")
    parser.add_argument(
        "--result-output",
        help="Optional machine-readable build result JSON.",
    )
    return parser.parse_args()


def load_json(path: Path) -> dict:
    return common.load_json(path)


def write_json(path: Path, payload: dict) -> None:
    common.write_json(path, payload)


def next_mode(mode: str) -> str:
    order = ["local-only", "targeted-delegation", "broad-delegation"]
    index = min(order.index(mode) + 1, len(order) - 1)
    return order[index]


def has_override_signal(context: dict, lint: dict) -> bool:
    merged = {}
    merged.update(context.get("override_signals", {}))
    merged.update(lint.get("override_signals", {}))
    return any(bool(value) for value in merged.values())


def compute_baseline_review_mode(context: dict) -> str:
    counts = context.get("counts", {})
    task_packet_count = max(int(counts.get("task_packet_count", 0)), len(PACKET_NAMES))
    changed_files = int(counts.get("changed_files", task_packet_count))
    batch_count = int(counts.get("batch_count", 0))

    mode = "local-only"
    if task_packet_count >= 5 or changed_files > 20 or batch_count >= 3:
        mode = "broad-delegation"
    elif task_packet_count >= 3 or batch_count >= 2:
        mode = "targeted-delegation"
    return mode


def apply_override_adjustment(
    review_mode: str,
    context: dict,
    lint: dict,
) -> tuple[str, bool, list[str]]:
    adjustments: list[str] = []
    override = has_override_signal(context, lint)
    if override:
        review_mode = next_mode(review_mode)
        adjustments.append("override_signal")
    return review_mode, override, adjustments


def maybe_apply_delegation_savings_floor(
    review_mode: str,
    packet_metrics: dict,
    adjustments: list[str],
) -> tuple[str, list[str]]:
    savings_tokens = int(packet_metrics.get("savings_tokens", 0) or 0)
    if (
        review_mode == "local-only"
        and savings_tokens >= DELEGATION_SAVINGS_FLOOR
        and "delegation_savings_floor" not in adjustments
    ):
        return "targeted-delegation", [*adjustments, "delegation_savings_floor"]
    return review_mode, adjustments


def base_worker_count(review_mode: str) -> int:
    return {
        "local-only": 0,
        "targeted-delegation": 2,
        "broad-delegation": 4,
    }[review_mode]


def recommended_worker_count(
    review_mode: str,
    review_mode_adjustments: list[str] | None = None,
) -> int:
    worker_count = base_worker_count(review_mode)
    if (
        review_mode == "targeted-delegation"
        and review_mode_adjustments
        and "delegation_savings_floor" in review_mode_adjustments
    ):
        return max(worker_count, 2)
    return worker_count


def active_worker_family_order() -> list[str]:
    if SPEC_METADATA["worker_return_contract"] == "classification-oriented":
        return ["context_findings", "candidate_producers", "verifiers"]
    return ["context_findings", "verifiers"]


def dedupe_preserve(items: list[str]) -> list[str]:
    deduped: list[str] = []
    seen: set[str] = set()
    for item in items:
        if item in seen:
            continue
        seen.add(item)
        deduped.append(item)
    return deduped


def post_draft_qa_workers(required_workers: list[dict], review_mode: str) -> list[dict]:
    if review_mode == "local-only":
        return []
    required_agent_types = {
        str(worker.get("agent_type") or "").strip() for worker in required_workers
    }
    verifier_types = [
        agent_type
        for agent_type in dedupe_preserve(
            SPEC_METADATA["preferred_worker_families"].get("verifiers", [])
        )
        if agent_type not in required_agent_types
    ]
    if not verifier_types:
        return []
    packets = ["global_packet.json"]
    if SPEC_METADATA.get("shared_local_packet"):
        packets.append(SPEC_METADATA["shared_local_packet"])
    if USES_BATCH_PACKETS:
        packets.append("batch-packet-01.json")
    else:
        packets.extend(f"{packet_name}.json" for packet_name in PACKET_NAMES)
    return [
        {
            "name": "post-draft-qa",
            "agent_type": verifier_types[0],
            "model": "gpt-5.4-mini",
            "reasoning_effort": "medium",
            "packets": dedupe_preserve(packets),
            "responsibility": (
                "Cross-check the local synthesis against packet evidence and "
                "flag coverage gaps, unsupported claims, or high-risk drift "
                "before finalize."
            ),
            "execution_class": "post_draft_qa",
            "stage": "post_draft",
        }
    ]


def recommended_workers(
    review_mode: str,
    review_mode_adjustments: list[str] | None = None,
) -> list[dict]:
    if review_mode == "local-only" or not SPEC_METADATA["packet_worker_map"]:
        return []
    budget = recommended_worker_count(review_mode, review_mode_adjustments)
    workers: list[dict] = []
    seen_assignments: set[tuple[str, str]] = set()
    ordered_packets: list[str] = []
    if USES_BATCH_PACKETS:
        ordered_packets.append("batch-packet-01")
    ordered_packets.extend(PACKET_NAMES)
    for packet_name in ordered_packets:
        for agent_type in SPEC_METADATA["packet_worker_map"].get(packet_name, []):
            assignment = (agent_type, packet_name)
            if assignment in seen_assignments:
                continue
            workers.append(
                {
                    "name": f"{packet_name.replace('_', '-')}-{agent_type}",
                    "agent_type": agent_type,
                    "model": "gpt-5.4-mini",
                    "reasoning_effort": "medium",
                    "packets": ["global_packet.json", f"{packet_name}.json"],
                    "responsibility": WORKER_INSTRUCTION_MAP.get(
                        agent_type,
                        WORKER_INSTRUCTION_MAP.get("docs_verifier", ""),
                    ),
                }
            )
            seen_assignments.add(assignment)
            if len(workers) >= budget:
                return workers
    return workers


def packet_order() -> list[str]:
    order = ["global_packet.json"]
    if SPEC_METADATA.get("shared_local_packet"):
        order.append(SPEC_METADATA["shared_local_packet"])
    if USES_BATCH_PACKETS:
        order.append("batch-packet-01.json")
    order.extend(f"{packet_name}.json" for packet_name in PACKET_NAMES)
    return order


